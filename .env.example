# Desktop app (apps/desktop) — bundled at build via electron-vite
# These reach the Electron main process; renderer access only via IPC.
OPENAI_API_KEY=
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
DEEPGRAM_API_KEY=
COHERE_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_REWRITE_MODEL=gpt-4o-mini
COHERE_RERANK_MODEL=rerank-english-v3.0

# Sync app (apps/sync) — local dev only; production EC2 reads from AWS SSM Parameter Store
SUPABASE_SERVICE_ROLE_KEY=

# Data-source credentials (sync side only; SSM in prod)
GDOCS_OAUTH_REFRESH_TOKEN=
GDOCS_OAUTH_CLIENT_ID=
GDOCS_OAUTH_CLIENT_SECRET=
SLACK_BOT_TOKEN=
NOTION_INTEGRATION_TOKEN=
GITHUB_TOKEN=
PITCH_API_TOKEN=
