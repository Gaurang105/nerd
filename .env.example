# nerd — main-process config (electron-vite exposes MAIN_VITE_* to the main process only).
# Copy to .env and fill in. Never commit the real .env.

# Gateway service (Node + ngrok) — fronts Postgres (/sql) and Qdrant (/search).
# This is the only data endpoint the app needs (no direct Qdrant/Postgres URLs).
MAIN_VITE_GATEWAY_URL=https://your-static-domain.ngrok-free.dev

# OpenAI — embeddings, query rewrite, generation
MAIN_VITE_OPENAI_API_KEY=sk-...

# Cohere — rerank
MAIN_VITE_COHERE_API_KEY=

# Deepgram — live transcription (mic + system audio)
MAIN_VITE_DEEPGRAM_API_KEY=

# Optional model overrides (defaults match the ERD)
MAIN_VITE_GEN_MODEL=gpt-5.5
MAIN_VITE_REWRITE_MODEL=gpt-5.4-mini
MAIN_VITE_EMBED_MODEL=text-embedding-3-small
MAIN_VITE_RERANK_MODEL=rerank-3.5
MAIN_VITE_TRANSCRIBE_MODEL=nova-3

# Set to "true" to embed a hypothetical answer (HyDE) instead of the question
MAIN_VITE_USE_HYDE=false
