{
  "name": "nerd",
  "version": "1.0.0",
  "private": true,
  "description": "Nerd — floating AI overlay for live calls",
  "author": "headout",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "pnpm --filter @nerd/desktop dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint --cache .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  }
}
