{
  "name": "@nerd/sync",
  "version": "1.0.0",
  "private": true,
  "description": "Nerd EC2 cron — differential sync from data sources into Qdrant + Supabase",
  "type": "module",
  "main": "./dist/cron.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/cron.js",
    "dev": "tsx watch src/cron.ts"
  },
  "dependencies": {
    "@nerd/chunker": "workspace:*",
    "@nerd/rag-clients": "workspace:*",
    "@nerd/shared": "workspace:*",
    "@qdrant/js-client-rest": "^1.18.0",
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^16.4.7",
    "googleapis": "^173.0.0",
    "node-cron": "^4.4.1",
    "openai": "^6.44.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
